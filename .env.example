# Copy to .env before running docker-compose up.
# Generate strong secrets with:
#   python -c "import secrets; print('sk-' + secrets.token_urlsafe(32))"

# Postgres password (used by the timescaledb container and backend connection strings)
POSTGRES_PASSWORD=change-me

# API key for the SDK and dashboard. On first startup the backend stores its
# hash in the database (only the hash is ever persisted).
API_KEY=sk-change-me

# --- Rate limiting & request size (optional; defaults shown) ---
# RATE_LIMIT_DEFAULT=120/minute
# RATE_LIMIT_INGEST=30/minute
# RATE_LIMIT_ENABLED=true
# RATE_LIMIT_STORAGE_URI=memory://   # use redis://host:6379 for multi-instance
# MAX_REQUEST_BYTES=10485760          # 10 MB

# --- PII redaction (optional; on by default) ---
# Redacts emails, cards, SSNs, phones, IPs and API keys from prompts/responses
# at ingestion, before storage. Set false to store raw text.
# PII_REDACTION_ENABLED=true
# PII_REDACTION_TYPES=email,credit_card,ssn,phone,ip,api_key

# --- Data retention (optional; disabled by default) ---
# Delete events older than N days. 0 keeps data forever.
# DATA_RETENTION_DAYS=0
# RETENTION_SWEEP_INTERVAL_HOURS=24
